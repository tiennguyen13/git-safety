#!/usr/bin/env bash
# pre-commit hook: blocks .env files and scans for common secret patterns
# Install via setup script: scripts/setup-git-hooks.sh

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

STAGED_FILES=$(git diff --cached --name-only)

# --- 1. Block .env files entirely (but allow .env.example templates) ---
ENV_FILES=$(echo "$STAGED_FILES" | grep -E "(^|/)\.env($|\.)" | grep -v "\.env\.example$")
if [ -n "$ENV_FILES" ]; then
  echo ""
  echo -e "${RED}❌ BLOCKED: .env file(s) detected in staged files:${NC}"
  echo "$ENV_FILES" | sed 's/^/   /'
  echo ""
  echo "   Run: git rm --cached <file>"
  echo "   Then add to .gitignore if not already there."
  echo ""
  exit 1
fi

# --- 2. Block other secret-like file extensions ---
SECRET_FILES=$(echo "$STAGED_FILES" | grep -Ei "\.(pem|key|p12|pfx|jks)$|^secrets?\.(json|yaml|yml)$|credentials?(\.json)?$")
if [ -n "$SECRET_FILES" ]; then
  echo ""
  echo -e "${RED}❌ BLOCKED: Potentially secret file(s) detected:${NC}"
  echo "$SECRET_FILES" | sed 's/^/   /'
  echo ""
  exit 1
fi

# --- 3. Scan content of staged files for secret patterns ---
PATTERNS=(
  "password[[:space:]]*=[[:space:]]*['\"][^'\"]{4,}"
  "secret[[:space:]]*=[[:space:]]*['\"][^'\"]{4,}"
  "api_key[[:space:]]*=[[:space:]]*['\"][^'\"]{4,}"
  "access_token[[:space:]]*=[[:space:]]*['\"][^'\"]{4,}"
)

# Private key header — match full PEM format to avoid false positives on code references
PRIVATE_KEY_MATCH=$(git diff --cached -U0 | grep "^+" | grep -F "-----BEGIN" | grep -iF "PRIVATE KEY-----")
if [ -n "$PRIVATE_KEY_MATCH" ]; then
  echo ""
  echo -e "${RED}❌ BLOCKED: Private key detected in staged diff:${NC}"
  echo "$PRIVATE_KEY_MATCH" | sed 's/^/   /'
  echo ""
  echo "   Use environment variables or a secret manager instead."
  echo "   If this is a false positive, contact your team lead."
  echo ""
  exit 1
fi

FOUND_SECRETS=0
for PATTERN in "${PATTERNS[@]}"; do
  MATCHES=$(git diff --cached -U0 | grep "^+" | grep -iEo "$PATTERN" | head -5)
  if [ -n "$MATCHES" ]; then
    if [ $FOUND_SECRETS -eq 0 ]; then
      echo ""
      echo -e "${RED}❌ BLOCKED: Possible secrets found in staged diff:${NC}"
    fi
    echo "$MATCHES" | sed 's/^/   /'
    FOUND_SECRETS=1
  fi
done

if [ $FOUND_SECRETS -eq 1 ]; then
  echo ""
  echo "   Use environment variables or a secret manager instead."
  echo "   If this is a false positive, contact your team lead."
  echo ""
  exit 1
fi

exit 0
