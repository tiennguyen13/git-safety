# Application
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=your-secret-key-here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your-password-here

# External APIs
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your-api-key-here

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h
